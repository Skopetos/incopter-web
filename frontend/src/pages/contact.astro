---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Επικοινωνία" description="Επικοινωνήστε με την Incopter για υπηρεσίες drone.">

  <!-- Page Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 grid-bg pointer-events-none opacity-50"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Επικοινωνία</p>
      <h1 class="text-5xl font-black text-white mb-6">Μιλήστε μαζί μας</h1>
      <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
        Έχετε ερωτήσεις ή θέλετε να ζητήσετε προσφορά; Συμπληρώστε τη φόρμα
        ή επικοινωνήστε απευθείας.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-10 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Contact form -->
        <div class="lg:col-span-2">
          <div class="bg-brand-card border border-brand-border rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">Φόρμα Επικοινωνίας</h2>

            <form id="contact-form" class="space-y-5" novalidate>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Όνομα *</label>
                  <input
                    type="text" id="name" name="name" required
                    placeholder="Το όνομά σας"
                    class="w-full bg-brand-surface border border-brand-border rounded-lg px-4 py-2.5 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-brand-accent transition-colors"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
                  <input
                    type="email" id="email" name="email" required
                    placeholder="email@example.com"
                    class="w-full bg-brand-surface border border-brand-border rounded-lg px-4 py-2.5 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-brand-accent transition-colors"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-300 mb-2">Τηλέφωνο</label>
                  <input
                    type="tel" id="phone" name="phone"
                    placeholder="69X XXX XXXX"
                    class="w-full bg-brand-surface border border-brand-border rounded-lg px-4 py-2.5 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-brand-accent transition-colors"
                  />
                </div>
                <div>
                  <label for="service" class="block text-sm font-medium text-slate-300 mb-2">Υπηρεσία</label>
                  <select
                    id="service" name="service"
                    class="w-full bg-brand-surface border border-brand-border rounded-lg px-4 py-2.5 text-sm text-slate-100 focus:outline-none focus:border-brand-accent transition-colors appearance-none"
                  >
                    <option value="" class="bg-brand-surface">Επιλέξτε υπηρεσία</option>
                    <option value="Μεταφορά Φορτίου"           class="bg-brand-surface">Μεταφορά Φορτίου</option>
                    <option value="Αεροψεκασμός & Σπορά"       class="bg-brand-surface">Αεροψεκασμός & Σπορά</option>
                    <option value="Εναέρια Χαρτογράφηση"       class="bg-brand-surface">Εναέρια Χαρτογράφηση</option>
                    <option value="Άλλο"                       class="bg-brand-surface">Άλλο</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Μήνυμα *</label>
                <textarea
                  id="message" name="message" required rows="5"
                  placeholder="Περιγράψτε μας την εργασία σας..."
                  class="w-full bg-brand-surface border border-brand-border rounded-lg px-4 py-2.5 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-brand-accent transition-colors resize-none"
                ></textarea>
              </div>

              <!-- feedback -->
              <div id="form-feedback" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

              <button
                type="submit"
                id="submit-btn"
                class="w-full sm:w-auto px-8 py-3.5 bg-brand-accent hover:bg-brand-accent-dark disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold rounded-lg transition-colors duration-200 flex items-center justify-center gap-2"
              >
                <span id="btn-text">Αποστολή Μηνύματος</span>
                <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
              </button>
            </form>
          </div>
        </div>

        <!-- Contact info -->
        <div class="space-y-4">
          <div class="bg-brand-card border border-brand-border rounded-2xl p-6">
            <h3 class="text-base font-bold text-white mb-5">Στοιχεία Επικοινωνίας</h3>
            <div class="space-y-5">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 mb-0.5">Email</p>
                  <a href="mailto:incopter.info@gmail.com" class="text-sm text-slate-200 hover:text-brand-accent transition-colors break-all">
                    incopter.info@gmail.com
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-9 h-9 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 mb-0.5">Τηλέφωνο</p>
                  <a href="tel:+306981748128" class="text-sm text-slate-200 hover:text-brand-accent transition-colors">
                    698 174 8128
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-brand-card border border-brand-border rounded-2xl p-6">
            <h3 class="text-base font-bold text-white mb-4">Ώρες Επικοινωνίας</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-slate-400">Δευτ – Παρ</span>
                <span class="text-slate-200">09:00 – 18:00</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400">Σάββατο</span>
                <span class="text-slate-200">09:00 – 14:00</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400">Κυριακή</span>
                <span class="text-slate-500">Κλειστά</span>
              </div>
            </div>
          </div>

          <div class="bg-brand-accent/10 border border-brand-accent/20 rounded-2xl p-5">
            <p class="text-sm text-slate-300 leading-relaxed">
              Απαντάμε συνήθως εντός <span class="text-brand-accent font-semibold">24 ωρών</span> σε κάθε αίτημα.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
  }
</style>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8080';

  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback') as HTMLDivElement;
  const btn      = document.getElementById('submit-btn')   as HTMLButtonElement;
  const btnText  = document.getElementById('btn-text')     as HTMLSpanElement;
  const spinner  = document.getElementById('btn-spinner')  as SVGElement;

  function setLoading(on: boolean) {
    btn.disabled = on;
    btnText.textContent = on ? 'Αποστολή…' : 'Αποστολή Μηνύματος';
    spinner.classList.toggle('hidden', !on);
  }

  function showFeedback(success: boolean, msg: string) {
    feedback.textContent = msg;
    feedback.className = `rounded-lg px-4 py-3 text-sm font-medium ${
      success
        ? 'bg-green-900/40 border border-green-700/50 text-green-400'
        : 'bg-red-900/40 border border-red-700/50 text-red-400'
    }`;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));

    if (!data.name || !data.email || !data.message) {
      showFeedback(false, 'Παρακαλώ συμπληρώστε τα υποχρεωτικά πεδία (*).');
      return;
    }

    setLoading(true);
    feedback.className = 'hidden';

    try {
      const res = await fetch(`${API_URL}/api/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      showFeedback(json.success, json.message);
      if (json.success) form.reset();
    } catch {
      showFeedback(false, 'Σφάλμα δικτύου. Δοκιμάστε ξανά ή επικοινωνήστε τηλεφωνικά.');
    } finally {
      setLoading(false);
    }
  });
</script>
