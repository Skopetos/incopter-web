---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Αρχική">

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <!-- grid background -->
    <div class="absolute inset-0 grid-bg pointer-events-none"></div>
    <!-- orange glow -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[700px] h-[700px] rounded-full bg-brand-accent-glow blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <!-- badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand-accent/30 bg-brand-accent/10 text-brand-accent text-sm font-medium mb-8">
        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
        Επαγγελματικές Υπηρεσίες Drone
      </div>

      <h1 class="text-5xl sm:text-7xl font-black tracking-tight leading-none mb-6">
        <span class="text-white">Incopter</span><br />
        
      </h1>

      <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Επαγγελματικές υπηρεσίες εναέριας τεχνολογίας. Μεταφορά φορτίων,
        αεροψεκασμός, σπορά και εναέρια χαρτογράφηση.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
        <a href="/services" class="w-full sm:w-auto px-8 py-3.5 bg-brand-accent hover:bg-brand-accent-dark text-white font-semibold rounded-lg transition-colors duration-200 text-center">
          Οι Υπηρεσίες μας
        </a>
      </div>

      <!-- stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          { value: '65kg',  label: 'Μέγιστο Φορτίο'     },
          { value: '70L',   label: 'Δεξαμενή Ψεκασμού'  },
          { value: '9m',    label: 'Εύρος Ψεκασμού'      },
          { value: 'IP67',  label: 'Αδιάβροχο'           },
        ].map(({ value, label }) => (
          <div class="bg-brand-card/60 border border-brand-border backdrop-blur-sm rounded-xl p-4">
            <p class="text-3xl font-black text-brand-accent">{value}</p>
            <p class="text-xs text-slate-400 mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-600 animate-bounce">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </div>
  </section>

  <!-- ─── SERVICES PREVIEW ──────────────────────────────────── -->
  <section class="py-24 bg-brand-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Τι κάνουμε</p>
        <h2 class="text-4xl font-bold text-white">Υπηρεσίες</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Cargo -->
        <a href="/services#cargo" class="group bg-brand-card border border-brand-border hover:border-brand-accent/50 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-brand-accent/10 border border-brand-accent/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Μεταφορά Φορτίου</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Ασφαλής και αξιόπιστη μεταφορά φορτίων έως <span class="text-brand-accent font-semibold">65kg</span>. Ιδανικό για δυσπρόσιτες τοποθεσίες και κάθε κατάσταση.
          </p>
          <div class="mt-6 flex items-center gap-1 text-brand-accent text-sm font-medium">
            Μάθετε περισσότερα
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        </a>

        <!-- Spraying -->
        <a href="/services#spraying" class="group bg-brand-card border border-brand-border hover:border-brand-accent/50 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-brand-accent/10 border border-brand-accent/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Αεροψεκασμός & Σπορά</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Αποδοτικός ψεκασμός και σπορά αγρών με κάλυψη <span class="text-brand-accent font-semibold">9 μέτρων</span>. Εξοικονόμηση χρόνου και αγροχημικών.
          </p>
          <div class="mt-6 flex items-center gap-1 text-brand-accent text-sm font-medium">
            Μάθετε περισσότερα
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        </a>

        <!-- Mapping -->
        <a href="/services#mapping" class="group bg-brand-card border border-brand-border hover:border-brand-accent/50 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1">
          <div class="w-12 h-12 bg-brand-accent/10 border border-brand-accent/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
            <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Εναέρια Χαρτογράφηση</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Ακριβής τοπογράφηση και χαρτογράφηση εδαφών. Ψηφιακά μοντέλα και ορθοφωτογραφίες υψηλής ανάλυσης.
          </p>
          <div class="mt-6 flex items-center gap-1 text-brand-accent text-sm font-medium">
            Μάθετε περισσότερα
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ─── DRONE HIGHLIGHT ───────────────────────────────────── -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- image placeholder -->
        <div class="relative aspect-video lg:aspect-square max-w-lg mx-auto lg:mx-0 w-full">
          <div class="w-full h-full rounded-2xl border-2 border-dashed border-brand-border flex flex-col items-center justify-center gap-4 bg-brand-card/30">
            <svg class="w-16 h-16 text-brand-border" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <circle cx="12" cy="12" r="3"/>
              <line x1="12" y1="12" x2="4.5"  y2="4.5"/>
              <line x1="12" y1="12" x2="19.5" y2="4.5"/>
              <line x1="12" y1="12" x2="4.5"  y2="19.5"/>
              <line x1="12" y1="12" x2="19.5" y2="19.5"/>
              <circle cx="4.5"  cy="4.5"  r="2.5"/>
              <circle cx="19.5" cy="4.5"  r="2.5"/>
              <circle cx="4.5"  cy="19.5" r="2.5"/>
              <circle cx="19.5" cy="19.5" r="2.5"/>
            </svg>
            <p class="text-slate-600 text-sm">Εδώ θα μπει η φωτογραφία του drone</p>
          </div>
          <!-- accent corner -->
          <div class="absolute -top-3 -right-3 w-24 h-24 border-t-2 border-r-2 border-brand-accent rounded-tr-2xl"></div>
          <div class="absolute -bottom-3 -left-3 w-24 h-24 border-b-2 border-l-2 border-brand-accent rounded-bl-2xl"></div>
        </div>

        <!-- text -->
        <div>
          <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Το drone μας</p>
          <h2 class="text-4xl font-bold text-white mb-2">Το Drone μας</h2>
          <p class="text-slate-500 text-sm mb-6 font-mono">Επαγγελματικός Εξοπλισμός Αιχμής</p>
          <p class="text-slate-400 leading-relaxed mb-8">
            Χρησιμοποιούμε επαγγελματικό drone γεωργικής κλάσης με εξαιρετικές επιδόσεις.
            Συνδυάζει ισχυρό φορτίο, έξυπνη πλοήγηση και υψηλή αξιοπιστία για κάθε εργασία.
          </p>

          <div class="grid grid-cols-2 gap-3">
            {[
              { label: 'Μέγιστο Φορτίο',      value: '65 kg'  },
              { label: 'Δεξαμενή Ψεκασμού',   value: '70 L'   },
              { label: 'Εύρος Ψεκασμού',       value: '9 m'    },
              { label: 'Ροή Ψεκασμού',         value: '48 L/min' },
              { label: 'Προστασία',            value: 'IP67'   },
              { label: 'Πλοήγηση',             value: 'RTK GPS' },
            ].map(({ label, value }) => (
              <div class="flex items-center gap-3 py-2 border-b border-brand-border/50">
                <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <div>
                  <p class="text-xs text-slate-500">{label}</p>
                  <p class="text-sm font-semibold text-white">{value}</p>
                </div>
              </div>
            ))}
          </div>

          <a href="/about" class="inline-flex items-center gap-2 mt-8 text-brand-accent font-medium hover:gap-3 transition-all">
            Μάθετε περισσότερα για εμάς
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── WHY US ─────────────────────────────────────────────── -->
  <section class="py-24 bg-brand-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Γιατί εμάς</p>
        <h2 class="text-4xl font-bold text-white">Τι μας κάνει διαφορετικούς</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            title: 'Τεχνολογία Αιχμής',
            desc: 'Χρησιμοποιούμε επαγγελματικό drone γεωργικής κλάσης με εξαιρετικές επιδόσεις και αξιοπιστία.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
          },
          {
            title: 'Πιστοποιημένοι Χειριστές',
            desc: 'Η ομάδα μας αποτελείται από πιστοποιημένους χειριστές drone με αποδεδειγμένη εμπειρία.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
          },
          {
            title: 'GPS Ακρίβεια',
            desc: 'Εγγυόμαστε αποτελεσματική εκτέλεση κάθε εργασίας με ακρίβεια RTK GPS.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
          },
          {
            title: 'Άμεση Ανταπόκριση',
            desc: 'Επικοινωνήστε μαζί μας και θα σας απαντήσουμε το συντομότερο δυνατό.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
          },
        ].map(({ title, desc, icon }) => (
          <div class="bg-brand-card border border-brand-border rounded-2xl p-6">
            <div class="w-10 h-10 bg-brand-accent/10 border border-brand-accent/20 rounded-lg flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={icon}></svg>
            </div>
            <h3 class="text-base font-bold text-white mb-2">{title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA BANNER ────────────────────────────────────────── -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden bg-brand-accent rounded-2xl px-8 py-14 text-center">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px), radial-gradient(circle at 80% 50%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
        <h2 class="relative text-3xl sm:text-4xl font-black text-white mb-4">Έτοιμοι να ξεκινήσετε;</h2>
        <p class="relative text-orange-100 mb-8 max-w-xl mx-auto">
          Επικοινωνήστε μαζί μας σήμερα και ενημερωθείτε για τις υπηρεσίες και τις τιμές μας.
        </p>
        <a
          href="/contact"
          class="inline-block px-8 py-3.5 bg-white text-brand-accent font-bold rounded-lg hover:bg-orange-50 transition-colors duration-200"
        >
          Επικοινωνήστε μαζί μας
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
  }
</style>
