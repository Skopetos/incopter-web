---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'cargo',
    title: 'Μεταφορά Φορτίου',
    subtitle: 'Έως 65kg σε οποιοδήποτε σημείο',
    desc: 'Με μέγιστο φορτίο 65kg, το drone μας μεταφέρει εφόδια, εξοπλισμό και άλλα αντικείμενα σε δυσπρόσιτες τοποθεσίες γρήγορα, ασφαλώς και χωρίς να απαιτείται χερσαία πρόσβαση.',
    features: [
      'Μέγιστο φορτίο 65 kg',
      'RTK GPS καθοδήγηση',
      'Ακριβής εναπόθεση φορτίου',
      'Λειτουργία σε δύσκολο ανάγλυφο',
      'Αισθητήρες αποφυγής εμποδίων',
      'Χρήση ακόμα και νύχτα',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>`,
    use_cases: ['Ορεινές περιοχές', 'Νησιά & απομονωμένα σημεία', 'Κατεπείγουσες παραδόσεις', 'Εργοτάξια'],
    image: '/images/lift.jpg',
  },
  {
    id: 'spraying',
    title: 'Αεροψεκασμός & Σπορά',
    subtitle: 'Αποδοτική γεωργία από ψηλά',
    desc: 'Το drone εξοπλίζεται με δεξαμενή 70 λίτρων και ψεκάζει σε πλάτος 9 μέτρων με ρυθμό έως 48L/min. Ιδανικό για ψεκασμό φυτοφαρμάκων, λιπασμάτων και σπορά αγρών με κατακόρυφη ακρίβεια.',
    features: [
      'Δεξαμενή ψεκασμού 70 L',
      'Εύρος ψεκασμού 9 m',
      'Ροή έως 48 L/min',
      'Ευφυής ακολούθηση εδάφους',
      'Αυτόματη αντίστροφη διαδρομή',
      'Διπλός ψεκαστήρας σπόρου',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    use_cases: ['Ελαιώνες', 'Αμπελώνες', 'Σιτηρά & καλαμπόκι', 'Οπωρώνες'],
    image: '/images/spray.jpg',
  },
  {
    id: 'mapping',
    title: 'Εναέρια Χαρτογράφηση & Τοπογράφηση',
    subtitle: 'Ακριβή δεδομένα για έξυπνες αποφάσεις',
    desc: 'Δημιουργούμε ακριβείς ψηφιακούς χάρτες, ορθοφωτογραφίες και τρισδιάστατα μοντέλα εδάφους. Τα δεδομένα μας χρησιμοποιούνται σε γεωργία, κατασκευές, διαχείριση εδαφών και μελέτες υποδομών.',
    features: [
      'Υψηλής ανάλυσης ορθοφωτογραφίες',
      'Ψηφιακό μοντέλο εδάφους (DTM)',
      'Ψηφιακό μοντέλο επιφανείας (DSM)',
      'Τρισδιάστατα μοντέλα (3D mesh)',
      'Δεδομένα GIS συμβατά',
      'NDVI χάρτες για γεωργία',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
    use_cases: ['Γεωργικές εκτάσεις', 'Κατασκευαστικά έργα', 'Μελέτες εδαφών', 'Διαχείριση δασών'],
    image: '/images/maping.jpg',
  },
];
---

<Layout title="Υπηρεσίες" description="Υπηρεσίες drone: μεταφορά φορτίου, αεροψεκασμός, σπορά και εναέρια χαρτογράφηση.">

  <!-- Page Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 grid-bg pointer-events-none opacity-50"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Τι προσφέρουμε</p>
      <h1 class="text-5xl font-black text-white mb-6">Υπηρεσίες</h1>
      <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
        Τρεις βασικές υπηρεσίες με επαγγελματικό εξοπλισμό και πιστοποιημένους χειριστές.
      </p>
    </div>
  </section>

  <!-- Services -->
  {services.map((s, i) => (
    <section
      id={s.id}
      class:list={['py-20 scroll-mt-16', i % 2 === 1 ? 'bg-brand-surface' : '']}
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-12 items-center', i % 2 === 1 ? 'lg:flex-row-reverse' : '']}>

          <!-- image -->
          <div class:list={['relative aspect-video rounded-2xl overflow-hidden', i % 2 === 1 ? 'lg:order-2' : '']}>
            {s.image ? (
              <img src={s.image} alt={s.title} class="w-full h-full object-cover rounded-2xl" />
            ) : (
              <div class="w-full h-full border-2 border-dashed border-brand-border flex flex-col items-center justify-center gap-3 bg-brand-card/30 rounded-2xl">
                <svg class="w-14 h-14 text-brand-border" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" set:html={`${s.icon}`}></svg>
                <p class="text-slate-600 text-sm px-4 text-center">Εδώ θα μπει φωτογραφία — {s.title}</p>
              </div>
            )}
          </div>

          <!-- text -->
          <div class:list={[i % 2 === 1 ? 'lg:order-1' : '']}>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-accent/10 border border-brand-accent/20 text-brand-accent text-xs font-semibold mb-4">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={s.icon}></svg>
              Υπηρεσία
            </div>
            <h2 class="text-3xl font-bold text-white mb-2">{s.title}</h2>
            <p class="text-slate-500 text-sm mb-4">{s.subtitle}</p>
            <p class="text-slate-400 leading-relaxed mb-8">{s.desc}</p>

            <!-- features -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8">
              {s.features.map(f => (
                <div class="flex items-center gap-2.5">
                  <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-slate-300">{f}</span>
                </div>
              ))}
            </div>

            <!-- use cases -->
            <div>
              <p class="text-xs text-slate-500 uppercase tracking-wider mb-3">Εφαρμογές</p>
              <div class="flex flex-wrap gap-2">
                {s.use_cases.map(uc => (
                  <span class="px-3 py-1 rounded-full bg-brand-card border border-brand-border text-xs text-slate-300">{uc}</span>
                ))}
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden bg-brand-accent rounded-2xl px-8 py-14 text-center">
        <h2 class="relative text-3xl font-black text-white mb-4">Χρειάζεστε προσφορά;</h2>
        <p class="relative text-orange-100 mb-8 max-w-xl mx-auto">
          Περιγράψτε μας την εργασία σας και θα σας στείλουμε προσφορά το συντομότερο δυνατό.
        </p>
        <a href="/contact" class="inline-block px-8 py-3.5 bg-white text-brand-accent font-bold rounded-lg hover:bg-orange-50 transition-colors duration-200">
          Ζητήστε προσφορά
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
  }
</style>
