---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Σχετικά" description="Μάθετε περισσότερα για την Incopter και τις επαγγελματικές υπηρεσίες drone μας.">

  <!-- Page Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 grid-bg pointer-events-none opacity-50"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Σχετικά με εμάς</p>
      <h1 class="text-5xl font-black text-white mb-6">Η Incopter</h1>
      <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
        Ελληνική εταιρεία εξειδικευμένη στις επαγγελματικές υπηρεσίες drone
        για γεωργία, μεταφορά φορτίων και εναέρια χαρτογράφηση.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 bg-brand-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Η αποστολή μας</p>
          <h2 class="text-3xl font-bold text-white mb-6">Αεροπορική τεχνολογία στην υπηρεσία σας</h2>
          <div class="space-y-4 text-slate-400 leading-relaxed">
            <p>
              Η <span class="text-white font-semibold">Incopter</span> ιδρύθηκε με έναν σαφή στόχο: να φέρει την
              εναέρια τεχνολογία σε κάθε γωνιά της Ελλάδας. Από τους αγρούς της υπαίθρου έως τα ορεινά
              και δυσπρόσιτα εδάφη, είμαστε εδώ για να παρέχουμε λύσεις που άλλοτε φαίνονταν αδύνατες.
            </p>
            <p>
              Πιστεύουμε ότι η σύγχρονη τεχνολογία drone μπορεί να μεταμορφώσει τη γεωργία,
              να επιταχύνει τη μεταφορά φορτίων και να δώσει δεδομένα που επιτρέπουν καλύτερες αποφάσεις
              σε κάθε τομέα.
            </p>
          </div>
        </div>

        <!-- image placeholder -->
        <div class="relative aspect-video rounded-2xl border-2 border-dashed border-brand-border flex flex-col items-center justify-center gap-3 bg-brand-card/30">
          <svg class="w-12 h-12 text-brand-border" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="text-slate-600 text-sm">Εδώ θα μπει φωτογραφία της ομάδας</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white">Οι αξίες μας</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Ασφάλεια', desc: 'Κάθε πτήση εκτελείται βάσει αυστηρών πρωτοκόλλων ασφαλείας. Δεν κάνουμε εκπτώσεις στην ασφάλεια.' },
          { title: 'Αποτελεσματικότητα', desc: 'Αξιοποιούμε στο έπακρο τις δυνατότητες της τεχνολογίας για να σας δώσουμε τα καλύτερα αποτελέσματα.' },
          { title: 'Αξιοπιστία', desc: 'Τηρούμε τις δεσμεύσεις μας. Εκτελούμε κάθε εργασία στον χρόνο και με την ποιότητα που έχουμε συμφωνήσει.' },
        ].map(({ title, desc }) => (
          <div class="bg-brand-card border border-brand-border rounded-2xl p-6">
            <div class="w-8 h-1 bg-brand-accent rounded mb-5"></div>
            <h3 class="text-lg font-bold text-white mb-3">{title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Drone Specs -->
  <section class="py-16 bg-brand-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-3">Ο εξοπλισμός μας</p>
        <h2 class="text-3xl font-bold text-white">Ο Εξοπλισμός μας</h2>
        <p class="text-slate-400 mt-3 max-w-xl mx-auto">
          Επαγγελματικό drone γεωργικής κλάσης με εξαιρετικές επιδόσεις σε κάθε συνθήκη.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

        <!-- image placeholder -->
        <div class="aspect-video rounded-2xl border-2 border-dashed border-brand-border flex flex-col items-center justify-center gap-3 bg-brand-card/30">
          <svg class="w-16 h-16 text-brand-border" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <circle cx="12" cy="12" r="3"/>
            <line x1="12" y1="12" x2="4.5"  y2="4.5"/>
            <line x1="12" y1="12" x2="19.5" y2="4.5"/>
            <line x1="12" y1="12" x2="4.5"  y2="19.5"/>
            <line x1="12" y1="12" x2="19.5" y2="19.5"/>
            <circle cx="4.5"  cy="4.5"  r="2.5"/>
            <circle cx="19.5" cy="4.5"  r="2.5"/>
            <circle cx="4.5"  cy="19.5" r="2.5"/>
            <circle cx="19.5" cy="19.5" r="2.5"/>
          </svg>
          <p class="text-slate-600 text-sm">Εδώ θα μπει φωτογραφία του drone</p>
        </div>

        <!-- specs grid -->
        <div class="grid grid-cols-2 gap-3">
          {[
            { label: 'Μέγιστο Φορτίο',        value: '65 kg'     },
            { label: 'Δεξαμενή Ψεκασμού',     value: '70 L'      },
            { label: 'Εύρος Ψεκασμού',         value: '9 m'       },
            { label: 'Ροή Ψεκασμού',           value: '48 L/min'  },
            { label: 'Προστασία',              value: 'IP67'      },
            { label: 'Πλοήγηση',               value: 'RTK GPS'   },
            { label: 'Ακολούθηση Εδάφους',     value: 'Ευφυής'    },
            { label: 'Αισθητήρες Αποφυγής',    value: 'Πολλαπλοί' },
          ].map(({ label, value }) => (
            <div class="bg-brand-card border border-brand-border rounded-xl p-4">
              <p class="text-xs text-slate-500 mb-1">{label}</p>
              <p class="text-lg font-bold text-brand-accent">{value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-card border border-brand-border rounded-2xl p-10 text-center">
        <h2 class="text-2xl font-bold text-white mb-3">Θέλετε να συνεργαστούμε;</h2>
        <p class="text-slate-400 mb-6">Επικοινωνήστε μαζί μας και θα σχεδιάσουμε μαζί τη λύση που σας ταιριάζει.</p>
        <a href="/contact" class="inline-block px-8 py-3.5 bg-brand-accent hover:bg-brand-accent-dark text-white font-semibold rounded-lg transition-colors duration-200">
          Επικοινωνήστε μαζί μας
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
  }
</style>
