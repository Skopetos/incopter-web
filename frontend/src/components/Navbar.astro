---
const links = [
  { href: '/',          label: 'Αρχική'    },
  { href: '/about',     label: 'Σχετικά'   },
  { href: '/services',  label: 'Υπηρεσίες' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-brand-bg/80 backdrop-blur-md border-b border-brand-border"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 bg-brand-accent rounded-lg flex items-center justify-center transition-transform group-hover:scale-110">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-white fill-none stroke-current stroke-2" stroke-linecap="round">
            <circle cx="12" cy="12" r="3"/>
            <line x1="12" y1="12" x2="4.5"  y2="4.5"/>
            <line x1="12" y1="12" x2="19.5" y2="4.5"/>
            <line x1="12" y1="12" x2="4.5"  y2="19.5"/>
            <line x1="12" y1="12" x2="19.5" y2="19.5"/>
            <circle cx="4.5"  cy="4.5"  r="2"/>
            <circle cx="19.5" cy="4.5"  r="2"/>
            <circle cx="4.5"  cy="19.5" r="2"/>
            <circle cx="19.5" cy="19.5" r="2"/>
          </svg>
        </div>
        <span class="text-lg font-bold tracking-tight text-white">Incopter</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors duration-200',
              (href === '/' ? path === '/' : path.startsWith(href))
                ? 'text-brand-accent'
                : 'text-slate-400 hover:text-white',
            ]}
          >
            {label}
          </a>
        ))}
        <a
          href="/contact"
          class="ml-2 px-4 py-2 bg-brand-accent hover:bg-brand-accent-dark text-white text-sm font-semibold rounded-lg transition-colors duration-200"
        >
          Επικοινωνήστε μαζί μας
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden p-2 text-slate-400 hover:text-white transition-colors"
        aria-label="Μενού"
      >
        <svg id="icon-open"  class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-brand-border bg-brand-surface">
    <div class="px-4 py-4 flex flex-col gap-1">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
            (href === '/' ? path === '/' : path.startsWith(href))
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-slate-300 hover:bg-brand-card hover:text-white',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 px-3 py-2.5 bg-brand-accent text-white text-sm font-semibold rounded-lg text-center"
      >
        Επικοινωνήστε μαζί μας
      </a>
    </div>
  </div>
</header>

<script>
  const btn   = document.getElementById('menu-btn');
  const menu  = document.getElementById('mobile-menu');
  const open  = document.getElementById('icon-open');
  const close = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const hidden = menu?.classList.toggle('hidden');
    open?.classList.toggle('hidden', !hidden);
    close?.classList.toggle('hidden', hidden ?? true);
  });
</script>
