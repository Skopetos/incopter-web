---
const year = new Date().getFullYear();
---

<footer class="bg-brand-surface border-t border-brand-border mt-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 bg-brand-accent rounded-lg flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-white fill-none stroke-current stroke-2" stroke-linecap="round">
              <circle cx="12" cy="12" r="3"/>
              <line x1="12" y1="12" x2="4.5"  y2="4.5"/>
              <line x1="12" y1="12" x2="19.5" y2="4.5"/>
              <line x1="12" y1="12" x2="4.5"  y2="19.5"/>
              <line x1="12" y1="12" x2="19.5" y2="19.5"/>
              <circle cx="4.5"  cy="4.5"  r="2"/>
              <circle cx="19.5" cy="4.5"  r="2"/>
              <circle cx="4.5"  cy="19.5" r="2"/>
              <circle cx="19.5" cy="19.5" r="2"/>
            </svg>
          </div>
          <span class="text-lg font-bold text-white">Incopter</span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Επαγγελματικές υπηρεσίες drone για γεωργία, μεταφορά φορτίων και εναέρια χαρτογράφηση.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Σελίδες</h3>
        <ul class="space-y-2.5">
          {[
            { href: '/',         label: 'Αρχική'      },
            { href: '/about',    label: 'Σχετικά'     },
            { href: '/services', label: 'Υπηρεσίες'   },
            { href: '/contact',  label: 'Επικοινωνία' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-slate-400 hover:text-brand-accent transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Επικοινωνία</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:incopter.info@gmail.com" class="text-sm text-slate-400 hover:text-brand-accent transition-colors break-all">incopter.info@gmail.com</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:+306981748128" class="text-sm text-slate-400 hover:text-brand-accent transition-colors">698 174 8128</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-brand-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">© {year} Incopter. Όλα τα δικαιώματα διατηρούνται.</p>
      <p class="text-xs text-slate-600">Επαγγελματικές Υπηρεσίες Drone</p>
    </div>
  </div>
</footer>
