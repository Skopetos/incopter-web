# Resend API key — get it from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Where contact emails are delivered
TO_EMAIL=incopter.info@gmail.com

# The "From" address — must be a domain you've verified in Resend
FROM_EMAIL=noreply@incopter.gr

# Allowed frontend origin for CORS
FRONTEND_URL=https://incopter.com

# Port
PORT=8080
